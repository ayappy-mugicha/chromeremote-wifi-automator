# Wi-Fi接続に基づいて制御したいサービスと、その起動を許可するSSIDを設定します。
# 形式: SERVICE_サービス名=対象のSSID
# （このSSIDに接続されているときだけそのサービスを開始し、それ以外のWi-Fiや未接続時には停止します）
#
# 例1：Chrome Remote Desktop (サービス名: chromoting)
SERVICE_chromoting=your_home_wifi_ssid
#
# 例2：別のサービス (サービス名: wuauserv ※Windows Update) をオフィスのWi-Fiでのみ稼働させたい場合
# SERVICE_wuauserv=your_office_wifi_ssid